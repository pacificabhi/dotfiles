{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": [
        "sway/workspaces",
        "hyprland/workspaces",
        "sway/window",
        "hyprland/window",
        "sway/mode",
        "hyprland/submap"
    ],
    "modules-center": [
    ],
    "modules-right": [
        "custom/disk",
        "temperature",
        "cpu",
        "memory",
        "custom/gpu",
        "pulseaudio",
        "battery",
        "network",
        "bluetooth",
        "clock",
        "tray"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "sway/window": {
        "format": "{}",
        "max-length": 50,
        "rewrite": {
            "(.*) — Mozilla Firefox": "\uf269 $1",
            "(.*) - Visual Studio Code": "\ue70c $1"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">\uf424 {}</span>",
        "tooltip": false
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "rewrite": {
            "(.*) — Mozilla Firefox": "\uf269 $1",
            "(.*) - Visual Studio Code": "\ue70c $1"
        }
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">\uf424 {}</span>",
        "tooltip": false
    },
    "clock": {
        "interval": 1,
        "format": "{:%a %b %d \uf017 %H:%M:%S}",
        "format-alt": "{:%Y-%m-%d \uf017 %H:%M:%S %Z}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "gnome-calendar",
        "on-click-right": "~/.config/waybar/scripts/toggle-calendar.sh"
    },
    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% \uf0e7",
        "format-plugged": "{capacity}% \uf1e6",
        "format-full": "{capacity}% \uf240",
        "format-icons": ["\uf244", "\uf243", "\uf242", "\uf241", "\uf240"],
        "tooltip-format": "{timeTo}, {capacity}%\n{power}W"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "\ueee8",
        "format-bluetooth": "{volume}% {icon} \uf294",
        "format-bluetooth-muted": "\uf6a8 {icon} \uf294",
        "format-icons": {
            "headphone": "\uf025",
            "hands-free": "\uf590",
            "headset": "\uf590",
            "phone": "\uf3cd",
            "portable": "\uf3cd",
            "car": "\uf1b9",
            "default": ["\uf026", "\uf027", "\uf028"]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
        "tooltip-format": "{desc}\nVolume: {volume}%"
    },
    "network": {
        "interval": 5,
        "format-wifi": "{essid} ({signalStrength}%) \uf063 {bandwidthDownBits} \uf062 {bandwidthUpBits}",
        "format-ethernet": "{ifname} \uf063 {bandwidthDownBits} \uf062 {bandwidthUpBits}",
        "format-disconnected": "Disconnected \u26a0",
        "tooltip-format": "{ifname} via {gwaddr}\nIP: {ipaddr}/{cidr}\nStrength: {signalStrength}%\nFrequency: {frequency}MHz",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor"
    },
    "bluetooth": {
      "format": " {status}",
      "format-connected": " {device_alias}",
      "format-connected-battery": " {device_alias} {device_battery_percentage}%",
      "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
      "on-click": "overskride" // This launches the GUI when you click the icon
    },
    "cpu": {
        "interval": 5,
        "format": "{usage}% ({load}) \uf4bc {avg_frequency}GHz",
        "format-alt": "{usage}% \uf4bc",
        "tooltip": true,
        "on-click": "kitty -e htop"
    },
    "memory": {
        "interval": 5,
        "format": "{used:0.1f}G/{total:0.1f}G \uefc5",
        "format-alt": "{percentage}% \uefc5",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e htop"
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        "interval": 5,
        "format": "{temperatureC}°C {icon}",
        "format-icons": ["\uf2cb", "\uf2ca", "\uf2c9", "\uf2c8", "\uf2c7"],
        "tooltip-format": "Temperature: {temperatureC}°C"
    },
    "custom/gpu": {
        "exec": "~/.config/waybar/scripts/gpu.sh",
        "return-type": "json",
        "interval": 5,
        "tooltip": true,
        "on-click": "nvidia-settings"
    },
    "custom/disk": {
        "exec": "~/.config/waybar/scripts/disk.sh",
        "return-type": "json",
        "interval": 30,
        "tooltip": true,
        "on-click": "baobab"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 8,
        "show-passive-items": true
    }
}
